<Window x:Class="Clap.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clap – Einstellungen"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <StackPanel Margin="20">
        <TextBlock Text="Anthropic API-Key" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <PasswordBox x:Name="ApiKeyBox" Padding="6" Margin="0,0,0,2"/>
        <TextBlock x:Name="ApiKeyHint" Foreground="Gray" FontSize="11" Margin="0,0,0,14"
                   Text="Der Key wird verschlüsselt (DPAPI) lokal gespeichert."/>

        <TextBlock Text="Modell" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox x:Name="ModelBox" Padding="6" Margin="0,0,0,14">
            <ComboBoxItem Tag="claude-opus-4-8" Content="Claude Opus 4.8 – beste Qualität"/>
            <ComboBoxItem Tag="claude-sonnet-4-6" Content="Claude Sonnet 4.6 – ausgewogen"/>
            <ComboBoxItem Tag="claude-haiku-4-5" Content="Claude Haiku 4.5 – am schnellsten"/>
        </ComboBox>

        <TextBlock Text="Standard-Zielsprache (Übersetzen)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox x:Name="LanguageBox" Padding="6" Margin="0,0,0,14">
            <ComboBoxItem Content="Deutsch"/>
            <ComboBoxItem Content="Englisch"/>
            <ComboBoxItem Content="Tschechisch"/>
        </ComboBox>

        <CheckBox x:Name="AutostartBox" Content="Automatisch mit Windows starten" Margin="0,0,0,18"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Speichern" Click="OnSaveClick" Padding="16,6" Margin="0,0,8,0" IsDefault="True"/>
            <Button Content="Abbrechen" Click="OnCancelClick" Padding="16,6" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
