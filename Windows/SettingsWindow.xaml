<Window x:Class="Clap.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clap – Einstellungen"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <StackPanel Margin="20">
        <TextBlock Text="Ollama-Server" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <DockPanel Margin="0,0,0,2">
            <Button x:Name="TestButton" Content="Verbinden" Click="OnTestClick"
                    DockPanel.Dock="Right" Padding="12,4" Margin="8,0,0,0"/>
            <TextBox x:Name="UrlBox" Padding="6"/>
        </DockPanel>
        <TextBlock x:Name="ConnectionHint" Foreground="Gray" FontSize="11" Margin="0,0,0,14"
                   Text="Lokal üblich: http://localhost:11434" TextWrapping="Wrap"/>

        <TextBlock Text="Textmodell (Übersetzen, Zusammenfassen, Erklären, Umformulieren)"
                   FontWeight="SemiBold" Margin="0,0,0,4" TextWrapping="Wrap"/>
        <ComboBox x:Name="ModelBox" IsEditable="True" Padding="6" Margin="0,0,0,14"/>

        <TextBlock Text="Vision-Modell (Bildanalyse, optional)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox x:Name="VisionModelBox" IsEditable="True" Padding="6" Margin="0,0,0,2"/>
        <TextBlock Foreground="Gray" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap"
                   Text="Leer lassen, um die Bildanalyse zu deaktivieren. Vision-Modell zuvor per &quot;ollama pull llava&quot; laden."/>

        <TextBlock Text="Standard-Zielsprache (Übersetzen)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox x:Name="LanguageBox" Padding="6" Margin="0,0,0,14">
            <ComboBoxItem Content="Deutsch"/>
            <ComboBoxItem Content="Englisch"/>
            <ComboBoxItem Content="Tschechisch"/>
        </ComboBox>

        <TextBlock Text="Shortcut" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox x:Name="HotkeyBox" Padding="6" Margin="0,0,0,2"/>
        <TextBlock Foreground="Gray" FontSize="11" Margin="0,0,0,14"
                   Text="Ist der Shortcut belegt (Windows reserviert z. B. Strg+Win+C teils für Farbfilter), weicht Clap automatisch auf eine Alternative aus."
                   TextWrapping="Wrap"/>

        <CheckBox x:Name="AutostartBox" Content="Automatisch mit Windows starten" Margin="0,0,0,18"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Speichern" Click="OnSaveClick" Padding="16,6" Margin="0,0,8,0" IsDefault="True"/>
            <Button Content="Abbrechen" Click="OnCancelClick" Padding="16,6" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
