<Window x:Class="Clap.Windows.ActionMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clap"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        WindowStartupLocation="Manual"
        Deactivated="OnDeactivated"
        KeyDown="OnKeyDown">
    <Border Background="#FF2B2B2B" CornerRadius="8" Padding="6"
            BorderBrush="#FF4A4A4A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel x:Name="ItemsPanel" MinWidth="240">
            <TextBlock x:Name="HeaderText" Foreground="#FF9E9E9E" FontSize="11"
                       Margin="8,4,8,6" TextTrimming="CharacterEllipsis" MaxWidth="320"/>
        </StackPanel>
    </Border>
</Window>
