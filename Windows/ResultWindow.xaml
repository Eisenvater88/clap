<Window x:Class="Clap.Windows.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clap"
        Width="620" Height="480"
        MinWidth="420" MinHeight="280"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="True"
        Background="#FF1E1E1E"
        KeyDown="OnKeyDown">
    <Window.Resources>
        <!-- Indeterminater Spinner: drei animierte Punkte -->
        <Style x:Key="Dot" TargetType="Ellipse">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Fill" Value="#FFE67E22"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Aktionstitel -->
            <RowDefinition Height="Auto"/> <!-- Quelle (Vorschau) -->
            <RowDefinition Height="Auto"/> <!-- Statuszeile -->
            <RowDefinition Height="Auto"/> <!-- Fortschritts-Balken -->
            <RowDefinition Height="*"/>    <!-- Ergebnisbereich -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <TextBlock x:Name="ActionTitle" Grid.Row="0" Foreground="#FFFFFFFF"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <Border Grid.Row="1" Background="#FF262626" CornerRadius="4"
                Padding="10,6" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="QUELLE" Foreground="#FF7A7A7A"
                           FontSize="10" Margin="0,0,0,2"/>
                <TextBlock x:Name="SourcePreview" Foreground="#FFBDBDBD"
                           FontSize="12" TextTrimming="CharacterEllipsis"
                           MaxHeight="48" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="Spinner" Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,8,0">
                <Ellipse Style="{StaticResource Dot}">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="Dot1Scale" ScaleX="1" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Style="{StaticResource Dot}">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="Dot2Scale" ScaleX="1" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Style="{StaticResource Dot}">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="Dot3Scale" ScaleX="1" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </StackPanel>

            <TextBlock x:Name="StatusText" Grid.Column="1" Foreground="#FFEAEAEA"
                       FontSize="12" VerticalAlignment="Center"
                       Text="Verbinde mit Ollama…"/>

            <TextBlock x:Name="ElapsedText" Grid.Column="2" Foreground="#FF7A7A7A"
                       FontSize="11" VerticalAlignment="Center"/>
        </Grid>

        <ProgressBar x:Name="ProgressIndicator" Grid.Row="3"
                     Height="3" IsIndeterminate="True"
                     Background="#FF2B2B2B" Foreground="#FFE67E22"
                     BorderThickness="0" Margin="0,0,0,10"/>

        <Border Grid.Row="4" Background="#FF2B2B2B" CornerRadius="6" Padding="2">
            <TextBox x:Name="OutputBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Background="Transparent"
                     Foreground="#FFEAEAEA"
                     BorderThickness="0"
                     FontSize="14"
                     Padding="12"/>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CopyButton" Content="Kopieren" Click="OnCopyClick"
                    Padding="16,6" Margin="0,0,8,0" IsEnabled="False"/>
            <Button x:Name="CloseButton" Content="Abbrechen"
                    Click="OnCloseClick" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
