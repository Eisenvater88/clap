<Window x:Class="Clap.Windows.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clap"
        Width="560" Height="420"
        MinWidth="380" MinHeight="240"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="True"
        Background="#FF1E1E1E"
        KeyDown="OnKeyDown">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText" Grid.Row="0" Foreground="#FF9E9E9E"
                   FontSize="12" Margin="2,0,2,8" Text="Anfrage läuft…"/>

        <Border Grid.Row="1" Background="#FF2B2B2B" CornerRadius="6" Padding="2">
            <TextBox x:Name="OutputBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Background="Transparent"
                     Foreground="#FFEAEAEA"
                     BorderThickness="0"
                     FontSize="14"
                     Padding="10"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CopyButton" Content="Kopieren" Click="OnCopyClick"
                    Padding="14,6" Margin="0,0,8,0" IsEnabled="False"/>
            <Button Content="Schließen" Click="OnCloseClick" Padding="14,6"/>
        </StackPanel>
    </Grid>
</Window>
